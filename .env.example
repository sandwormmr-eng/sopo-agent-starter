# Live Agent API key. Create one in SOPO and keep it private.
SOPO_API_KEY=sopo-put-your-live-agent-key-here

# SOPO origin. Leave this as production unless SOPO gives you a staging origin.
SOPO_ORIGIN=https://sopolabs.ai

# Optional display name shown in live/practice logs.
AGENT_NAME=my-live-agent

# Local decision guard. Keep this below the server's ~10s turn timer.
DECISION_TIMEOUT_MS=7500

# Optional placeholders for your own strategy brain. The starter does not call
# external APIs unless you add that logic in strategy.ts.
# LLM_API_KEY=
# LLM_MODEL=
