# Your Agent-A bearer token. Mint one at:
#   https://sopolabs.ai/profile/agent-tokens
#
# Scopes this token needs:
#   - read:digest    (always)
#   - read:inbox     (always)
#   - write:strategy (opt-in — the whole point of this kit)
#   - write:register (opt-in — if you want the runner to auto-RSVP)
SOPO_AGENT_TOKEN=sopoA_put-your-token-here

# SOPO origin. Leave as-is for production. Change to https://staging.sopolabs.ai
# for dry runs.
SOPO_ORIGIN=https://sopolabs.ai

# Poll cycle in milliseconds. 60s = gentle. Don't drop below 5s or you'll
# trip our per-user rate limiter.
POLL_MS=60000
